SERVER_ADDR=127.0.0.1:3001

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

POSTGRES_USER=snake
POSTGRES_PASSWORD=snake
POSTGRES_DB=snake

# Optional override. When set, this takes precedence over the split database values above.
# DATABASE_URL=postgres://snake:snake@127.0.0.1:5432/snake

# Optional aliases for the server only. If set, these take precedence over POSTGRES_*.
# DATABASE_USER=snake
# DATABASE_PASSWORD=snake
# DATABASE_NAME=snake
